# Poliscope — Environment Variables
# Copy this file to .env.local and fill in your values.
# The app works fully in guest mode without these — they only enable cloud save.

# ── Supabase (optional) ──────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Notes ────────────────────────────────────────────────────────────────────
# - Variables MUST be prefixed with VITE_ to be accessible in the browser
# - Never commit .env.local to git (it is already in .gitignore)
# - On Vercel: add these under Project → Settings → Environment Variables
